{
  "repo": "plume-move-clock-scope",
  "language": "Elixir",
  "category": "Chess and game engines",
  "goal": "Build an Elixir toolkit that studies clock behavior through seeded input scenarios, with deterministic summary checks and no production deployment claims.",
  "review_model": {
    "terms": [
      "position pressure",
      "move ordering",
      "search width",
      "endgame risk"
    ],
    "lanes": [
      "ship",
      "watch",
      "hold"
    ],
    "score": "signal * 2 + slack + confidence - drag * 3",
    "purpose": "surface the domain-specific cases that need the most careful review"
  },
  "cases": [
